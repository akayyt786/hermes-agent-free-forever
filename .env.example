# DeepSeek Authentication (To get this: Go to chat.deepseek.com, open Console, and run: console.log(JSON.parse(localStorage.getItem('user_token')).value))
DEEPSEEK_AUTH_TOKEN="your_token_here"

# Bridge Configuration
BRIDGE_PORT=8000
BRIDGE_HOST=0.0.0.0

# Performance & Jitter
MIN_DELAY_SECONDS=1.5
MAX_JITTER_SECONDS=1.5

# Advanced Settings
REVIEW_MODE=always
AUTO_ACCEPT_READS=true
PROJECT_SCAN_ON_START=true
MAX_CONTEXT_CHARS=100000
SESSION_POOL_SIZE=3
MAX_RETRIES=3
LOG_REQUESTS=true
